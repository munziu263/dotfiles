# Lazy.nvim lockfile (machine-specific)
lazy-lock.json

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# macOS
.DS_Store

# Editor
*.swp
*.swo
*~

# Claude/Copilot local settings (but track claude-plugins stow package)
!claude-plugins/
CLAUDE.md

# Machine-specific aliases (not tracked)
shell/.aliases.*
tmux/.config/tmux/plugins/

# Ghostty backups
ghostty/.config/ghostty/*.bak
